{
  "manifest_version": 3,
  "name": "AI Phishing Email Detector",
  "version": "1.0.0",
  "description": "Scans selected text and email bodies for phishing indicators and threat levels using AI.",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
